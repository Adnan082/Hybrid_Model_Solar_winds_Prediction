          <mxGeometry x="75" y="268" width="800" height="118" as="geometry" />
        </mxCell>
        <mxCell id="a1-title" value="AGENT 1 — Burton Physics Solver  (no ML training required)"
          style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=12;fontStyle=1;fontColor=#b85450;"
          vertex="1" parent="1">
          <mxGeometry x="90" y="271" width="560" height="20" as="geometry" />
        </mxCell>

        <mxCell id="a1-ode" value="&lt;b&gt;ODE Solver (RK4)&lt;/b&gt;&#xa;dDst/dt = Q(E) − Dst / τ&#xa;Q = −4.4 (E − 0.49)&#xa;τ = 7.7 hrs"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffcccc;strokeColor=#b85450;fontSize=10;"
          vertex="1" parent="1">
          <mxGeometry x="95" y="295" width="200" height="78" as="geometry" />
        </mxCell>

        <mxCell id="a1-out" value="&lt;b&gt;Published outputs:&lt;/b&gt;   Dst_burton(t)   ·   Q(t) ring current injection rate   ·   E(t) solar wind electric field&#xa;dDst_burton/dt rate of change   ·   rolling_error_3hr (how wrong Burton was in last 3 hrs)   ·   storm_phase"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffcccc;strokeColor=#b85450;fontSize=10;align=left;"
          vertex="1" parent="1">
          <mxGeometry x="315" y="295" width="540" height="78" as="geometry" />
        </mxCell>

        <!-- EB2 -->
        <mxCell id="eb2" value="EVENT BUS (Redis Pub/Sub)   ·   topic: burton.output"
