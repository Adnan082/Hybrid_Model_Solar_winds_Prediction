        </mxCell>

        <!-- ===== AGENT 2 ===== -->
        <mxCell id="a2-bg" value=""
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;"
          vertex="1" parent="1">
          <mxGeometry x="25" y="510" width="445" height="178" as="geometry" />
        </mxCell>
        <mxCell id="a2-title" value="AGENT 2 — Anomaly Detection (Unsupervised)"
          style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=12;fontStyle=1;fontColor=#2d7600;"
          vertex="1" parent="1">
          <mxGeometry x="40" y="513" width="400" height="20" as="geometry" />
        </mxCell>

        <mxCell id="a2-model" value="&lt;b&gt;LSTM Autoencoder&lt;/b&gt;&#xa;Unsupervised&#xa;Trained on quiet-period solar wind&#xa;Reconstruction error = anomaly score"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ccff99;strokeColor=#82b366;fontSize=10;"
          vertex="1" parent="1">
          <mxGeometry x="42" y="538" width="200" height="78" as="geometry" />
        </mxCell>

        <mxCell id="a2-io" value="&lt;b&gt;Inputs:&lt;/b&gt;&#xa;raw solar wind: Bz, speed, density, temp&#xa;Q(t), E(t) from Agent 1&#xa;&#xa;&lt;b&gt;Output:&lt;/b&gt; anomaly_score A(t) ∈ [0,1]&#xa;High score = unusual solar wind&#xa;→ Burton likely to fail here"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ccff99;strokeColor=#82b366;fontSize=10;align=left;"
          vertex="1" parent="1">
          <mxGeometry x="255" y="536" width="200" height="138" as="geometry" />
        </mxCell>

        <!-- ===== AGENT 3 ===== -->
        <mxCell id="a3-bg" value=""
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;"
          vertex="1" parent="1">
          <mxGeometry x="510" y="510" width="465" height="178" as="geometry" />
        </mxCell>
        <mxCell id="a3-title" value="AGENT 3 — Supervised Error Corrector"
          style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=12;fontStyle=1;fontColor=#7d4f00;"
          vertex="1" parent="1">
          <mxGeometry x="525" y="513" width="420" height="20" as="geometry" />
        </mxCell>

        <mxCell id="a3-model" value="&lt;b&gt;LSTM (seq2seq)&lt;/b&gt;&#xa;Supervised&#xa;Target: dst_actual − dst_burton&#xa;Learns WHERE / HOW Burton fails"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffee99;strokeColor=#d6b656;fontSize=10;"
          vertex="1" parent="1">
          <mxGeometry x="527" y="538" width="210" height="78" as="geometry" />
        </mxCell>

        <mxCell id="a3-io" value="&lt;b&gt;Inputs:&lt;/b&gt;&#xa;Dst_burton, Q(t), E(t), dDst/dt&#xa;rolling_error_3hr, storm_phase&#xa;anomaly_score A(t)&#xa;&#xa;&lt;b&gt;Output:&lt;/b&gt; correction Δ(t)&#xa;Dst_corrected = Dst_burton + Δ(t)"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffee99;strokeColor=#d6b656;fontSize=10;align=left;"
          vertex="1" parent="1">
          <mxGeometry x="752" y="536" width="208" height="138" as="geometry" />
        </mxCell>

