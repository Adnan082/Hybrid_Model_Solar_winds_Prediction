        <mxCell id="a4-bg" value=""
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;"
          vertex="1" parent="1">
          <mxGeometry x="25" y="812" width="950" height="205" as="geometry" />
        </mxCell>
        <mxCell id="a4-title" value="AGENT 4 — Reinforcement Learning Arbiter  (online learning — adapts live during active storms)"
          style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=12;fontStyle=1;fontColor=#00478f;"
          vertex="1" parent="1">
          <mxGeometry x="40" y="815" width="870" height="20" as="geometry" />
        </mxCell>

        <mxCell id="a4-state" value="&lt;b&gt;STATE&lt;/b&gt;&#xa;&#xa;Dst_burton(t)&#xa;anomaly_score A(t)&#xa;correction Δ(t)&#xa;storm_phase&#xa;last 6 hr pred errors&#xa;solar wind context"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#99ccff;strokeColor=#6c8ebf;fontSize=10;align=left;"
          vertex="1" parent="1">
          <mxGeometry x="43" y="840" width="185" height="160" as="geometry" />
        </mxCell>

        <mxCell id="a4-policy" value="&lt;b&gt;POLICY (PPO)&lt;/b&gt;&#xa;&#xa;Learns weights w1, w2, w3&#xa;&#xa;Dst_final = w1 · Dst_burton&#xa;          + w2 · Dst_corrected&#xa;          + w3 · anomaly_adj&#xa;&#xa;quiet  → w1≈1.0, w2≈0&#xa;onset  → w1 drops, w2 rises&#xa;main   → w1≈0,   w2≈1.0"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#99ccff;strokeColor=#6c8ebf;fontSize=10;align=left;"
          vertex="1" parent="1">
          <mxGeometry x="245" y="840" width="240" height="160" as="geometry" />
        </mxCell>

        <mxCell id="a4-reward" value="&lt;b&gt;REWARD SIGNAL&lt;/b&gt;&#xa;&#xa;Every hour, true Dst arrives:&#xa;reward = −|Dst_final − Dst_actual|&#xa;&#xa;Bonus:   +10 if G-level correct&#xa;Penalty: −20 if extreme storm missed&#xa;&#xa;&lt;b&gt;Agent gets smarter each storm&lt;/b&gt;"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#99ccff;strokeColor=#6c8ebf;fontSize=10;align=left;"
          vertex="1" parent="1">
          <mxGeometry x="505" y="840" width="220" height="160" as="geometry" />
        </mxCell>

        <mxCell id="a4-output" value="&lt;b&gt;OUTPUT&lt;/b&gt;&#xa;&#xa;Dst_final(t)&#xa;confidence score&#xa;storm G-level&#xa;G0 quiet → G5 extreme&#xa;&#xa;weights w1, w2, w3&#xa;(full explainability)"
          style="rounded=1;whiteSpace=wrap;html=1;fillColor=#99ccff;strokeColor=#6c8ebf;fontSize=10;align=left;"
          vertex="1" parent="1">
          <mxGeometry x="745" y="840" width="210" height="160" as="geometry" />
